CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
FX_WORKER_BASE_URL=

# Prefer a dedicated DSN for the currency project.
# Shared SENTRY_DSN is supported as a fallback in GitHub Actions,
# but SENTRY_CURRENCY_API_DSN is the preferred secret/env name.
SENTRY_CURRENCY_API_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
CRON_SECRET=

# Grafana Cloud Worker traces. Use either the standard Grafana OTLP env vars
# or the repo alias pair below. OTEL_EXPORTER_OTLP_TRACES_ENDPOINT takes
# precedence over OTEL_EXPORTER_OTLP_ENDPOINT when both are present.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_ENDPOINT=
OTEL_AUTH_HEADER=

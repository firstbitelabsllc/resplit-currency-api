CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Prefer a dedicated DSN for the currency publisher project.
# Shared SENTRY_DSN is supported as a fallback in GitHub Actions,
# but SENTRY_CURRENCY_API_DSN is the preferred secret/env name.
SENTRY_CURRENCY_API_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

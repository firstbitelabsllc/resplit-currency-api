{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Google Managed Prometheus / Cloud Monitoring datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Resplit OCR (Cloud Run) golden signals: scan volume, latency percentiles, 3-way error split, App Attest pass/soft-fail, per-device top-N, CDN cache-hit, and Azure DI cost proxy.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["resplit", "ocr", "cloud-run", "golden-signals"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "ocr", "value": "ocr" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(http_requests_total, service_name)",
        "hide": 0,
        "includeAll": false,
        "label": "Service",
        "multi": false,
        "name": "service",
        "options": [],
        "query": { "query": "label_values(http_requests_total, service_name)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Resplit — OCR Service",
  "uid": "resplit-ocr",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Volume & Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Scan volume (5m rate)",
      "description": "Successful /ocr/scan requests per second over the last 5 minutes.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{route=\"/ocr/scan\", status_class=\"2xx\"}[5m]))",
          "legendFormat": "scans/s",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total scans (24h)",
      "description": "Successful scans completed in the last 24h.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(increase(http_requests_total{route=\"/ocr/scan\", status_class=\"2xx\"}[24h]))",
          "legendFormat": "24h",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Scan request volume by status class",
      "description": "Stacked request rate to /ocr/scan, split by HTTP status class.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 35,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 1,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (status_class) (rate(http_requests_total{route=\"/ocr/scan\"}[5m]))",
          "legendFormat": "{{status_class}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Scan latency p50 / p95 / p99",
      "description": "Percentile latency for /ocr/scan computed from the http_request_duration_seconds histogram.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"], "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{route=\"/ocr/scan\"}[5m])))",
          "legendFormat": "p50",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{route=\"/ocr/scan\"}[5m])))",
          "legendFormat": "p95",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{route=\"/ocr/scan\"}[5m])))",
          "legendFormat": "p99",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "Errors & Abuse",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 101,
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "3-way error split (5xx / 4xx-abuse / provider)",
      "description": "Three independent failure modes: 5xx server errors, App-Attest/abuse rejections (4xx gate), and provider/gateway failures (502/503 from Azure DI).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx server" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "abuse rejected (gate)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } } ] },
          { "matcher": { "id": "byName", "options": "provider/gateway (non-abuse 4xx)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"], "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{route=\"/ocr/scan\", status_class=\"5xx\"}[5m]))",
          "legendFormat": "5xx server",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(ocr_abuse_rejections_total[5m]))",
          "legendFormat": "abuse rejected (gate)",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{route=\"/ocr/scan\", status_class=\"4xx\"}[5m])) - sum(rate(ocr_abuse_rejections_total[5m]))",
          "legendFormat": "provider/gateway (non-abuse 4xx)",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Abuse rejections by reason",
      "description": "ocr_abuse_rejections_total broken out by reason (attest error code: REPLAY, SIG, UNKNOWN_KEY, RPID, BUDGET, RATE_CAP, ...).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"], "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (reason) (rate(ocr_abuse_rejections_total[5m]))",
          "legendFormat": "{{reason}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "App-Attest pass ratio",
      "description": "Fraction of attest+scan attempts that passed the gate vs total (passed + rejected). Soft-fail = rejections that are recoverable (e.g. NONCE/CHALLENGE timing) vs hard rejections (REPLAY/SIG).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.9 }, { "color": "green", "value": 0.98 } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{route=\"/ocr/scan\", status_class=\"2xx\"}[30m])) / clamp_min(sum(rate(http_requests_total{route=\"/ocr/scan\", status_class=\"2xx\"}[30m])) + sum(rate(ocr_abuse_rejections_total[30m])), 1)",
          "legendFormat": "pass ratio",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "App-Attest pass vs soft-fail vs hard-fail",
      "description": "Pass = 2xx scans. Soft-fail = recoverable gate rejections (NONCE, NOKEY, COUNT). Hard-fail = security rejections (REPLAY, SIG, RPID, CHAIN, UNKNOWN_KEY).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 30, "stacking": { "mode": "percent", "group": "A" }, "lineWidth": 1, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "pass" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "soft-fail" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "hard-fail" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{route=\"/ocr/scan\", status_class=\"2xx\"}[5m]))",
          "legendFormat": "pass",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(ocr_abuse_rejections_total{reason=~\"NONCE|NOKEY|COUNT|CBOR_BAD|ASSERT_B64|ASSERT_SHAPE|ATT_B64|ATT_SHAPE|AUTHDATA\"}[5m]))",
          "legendFormat": "soft-fail",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(ocr_abuse_rejections_total{reason=~\"REPLAY|SIG|RPID|CHAIN|UNKNOWN_KEY|FMT|BUDGET|RATE_CAP\"}[5m]))",
          "legendFormat": "hard-fail",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "Devices, CDN & Cost",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "panels": []
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top-N devices by rejections (abuse heat)",
      "description": "Devices with the most abuse rejections in the window. Requires a device_id label on ocr_abuse_rejections_total (added at record time when available); falls back to reason aggregation if absent.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rejections (15m)" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }, { "id": "unit", "value": "short" } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "rejections (15m)", "desc": true } ] },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "topk(10, sum by (device_id, reason) (increase(ocr_abuse_rejections_total[15m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "rejections (15m)", "device_id": "device", "reason": "reason" }, "excludeByName": { "Time": true } } }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CDN cache-hit ratio (FX read-path)",
      "description": "Cloud CDN hit ratio in front of the GCS FX bucket. Hits keep OCR/Cloud Run compute idle; a drop means origin traffic + cost. Requires CDN log-based metric load_balancing_googleapis_com:https_request_count by cache_result.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.9 }, { "color": "green", "value": 0.95 } ] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(loadbalancing_googleapis_com:https_request_count{cache_result=~\"HIT|hit\"}[5m])) / clamp_min(sum(rate(loadbalancing_googleapis_com:https_request_count[5m])), 1)",
          "legendFormat": "cache-hit ratio",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Azure DI cost proxy — today",
      "description": "Cumulative OCR spend (USD) so far today, derived from ocr_scan_cost_usd_total. This is the per-page Azure Document Intelligence cost proxy that feeds the daily-budget alert.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 39 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 8 }, { "color": "red", "value": 10 } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(increase(ocr_scan_cost_usd_total[1d]))",
          "legendFormat": "today",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "OCR spend rate (USD/hour)",
      "description": "Hourly burn of Azure DI cost. The daily-budget alert projects this against the budget cap.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 39 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "showPoints": "never" },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(ocr_scan_cost_usd_total[1h])) * 3600",
          "legendFormat": "USD/hour",
          "range": true,
          "refId": "A"
        }
      ]
    }
  ]
}

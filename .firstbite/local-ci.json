{
  "version": 1,
  "repo": "resplit_currency_api",
  "display": "Resplit FX",
  "localCi": {
    "owner": "repo",
    "lanes": {
      "resplit_currency_api_unit": {
        "kind": "unit",
        "command": "npm ci && npm run generate && npm run test",
        "timeoutMs": 1200000
      },
      "resplit_currency_api_integration": {
        "kind": "integration",
        "command": "npm ci && npm run check",
        "timeoutMs": 1500000
      },
      "resplit_currency_api_ui": {
        "kind": "ui",
        "command": "npm ci && npm run smoke:deploy",
        "timeoutMs": 1500000,
        "note": "Live Worker/CDN smoke; this repo has no browser UI, so the UI lane is the user-facing FX contract smoke."
      }
    }
  }
}

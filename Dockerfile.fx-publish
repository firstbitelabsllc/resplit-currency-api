# syntax=docker/dockerfile:1
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOFLAGS=-trimpath \
    go build -ldflags="-s -w" -o /out/fx-publish ./cmd/fx-publish
FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/fx-publish /fx-publish
USER 65532:65532
ENTRYPOINT ["/fx-publish"]

{
  "name": "resplit-fx",
  "main": "worker/src/index.mjs",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["nodejs_compat"],
  // Daily FX canary — Sentry monitor resplit-currency-api-fx-canary expects 13:00 UTC.
  "triggers": {
    "crons": ["0 13 * * *"]
  },
  "workers_dev": true,
  "upload_source_maps": true,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "destinations": ["grafana-logs-prod"]
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1,
      "destinations": ["grafana-traces-prod"]
    }
  },
  "vars": {
    "ASSET_BASE_URL": "https://resplit-currency-api.pages.dev",
    "SENTRY_ENVIRONMENT": "production",
    // Distributed tracing sample rate for the FX worker (env-driven, default 0.05).
    "SENTRY_TRACES_RATE": "0.05",
    // OCR proxy: Azure DI endpoint (NOT secret). The key is a wrangler secret.
    // Current deploy uses root --env="", so sync AZURE_OCR_KEY on the root script.
    "AZURE_OCR_ENDPOINT": "https://superfit.cognitiveservices.azure.com",
    // Shared /ocr/scan, /ocr/dual-scan, and /ocr/analyze ingress ceiling. Installed
    // iOS clients preprocess JPEGs to <=2,000 KiB; 10 MiB preserves that contract
    // while bounding Worker memory before auth, caps, cache, or provider calls.
    "OCR_MAX_INGRESS_BYTES": "10485760",
    // Per-request Azure transport deadline. Malformed/out-of-range values fail safe to 15s.
    "AZURE_OCR_FETCH_TIMEOUT_MS": "15000",
    // Discount/credit/fee capture via a 2nd prebuilt-layout keyValuePairs Azure call
    // (router.mjs keyValueExtrasEnabled). 2x cost/scan — APPROVED by Leo 2026-06-22 (low
    // traffic). Revertible: set "false" + redeploy.
    "AZURE_OCR_KV_EXTRAS": "true",
    // /ocr/dual-scan Anthropic leg. ANTHROPIC_API_KEY is a wrangler secret; empty allowlist
    // ships the endpoint dark until specific App Attest keyIds are admitted.
    "LLM_SCAN_MODEL": "claude-sonnet-5",
    "LLM_SCAN_ALLOWED_KEY_IDS": "",
    "LLM_SCAN_DAILY_CAP": "3000",
    "SOFT_FAIL_DAILY_CAP": "150",
    // pre-launch dev unlock — set false at public launch (see router readLlmGate)
    "LLM_SCAN_ALLOW_SOFT_FAIL": "true"
  },
  "kv_namespaces": [
    {
      "binding": "ATTEST_KV",
      "id": "1bfd321b53ab48f2ad45e9b4f18efe03"
    }
  ],
  "r2_buckets": [
    {
      "binding": "SIDELOAD_R2",
      "bucket_name": "resplit-sideload-staging"
    }
  ],
  // Per-scan OCR recovery telemetry (router.mjs writeOcrScanAnalytics): what the AI
  // (vision-LLM) leg catches that Azure's prebuilt parse misses — the pro-tier
  // AI-scan product signal. Free tier, zero added latency; the dataset auto-creates
  // on first write (no account-level setup for WRITES — querying uses the AE SQL
  // API). No PII: scanId is a per-scan UUID, never a device/user id.
  "analytics_engine_datasets": [
    {
      "binding": "OCR_SCAN_ANALYTICS",
      "dataset": "ocr_scan_recovery"
    }
  ],
  "env": {
    "production": {
      "name": "resplit-fx",
      "observability": {
        "enabled": true,
        "logs": {
          "enabled": true,
          "head_sampling_rate": 0.1,
          "destinations": ["grafana-logs-prod"]
        },
        "traces": {
          "enabled": true,
          "head_sampling_rate": 0.1,
          "destinations": ["grafana-traces-prod"]
        }
      },
      "vars": {
        "ASSET_BASE_URL": "https://resplit-currency-api.pages.dev",
        "SENTRY_ENVIRONMENT": "production",
        "SENTRY_TRACES_RATE": "0.05",
        "AZURE_OCR_ENDPOINT": "https://superfit.cognitiveservices.azure.com",
        // Keep the named production env aligned with the root worker deployed by run.yml.
        "OCR_MAX_INGRESS_BYTES": "10485760",
        "AZURE_OCR_FETCH_TIMEOUT_MS": "15000",
        // Discount/credit/fee capture (2x cost/scan) — APPROVED Leo 2026-06-22. Revert: "false".
        "AZURE_OCR_KV_EXTRAS": "true",
        "LLM_SCAN_MODEL": "claude-sonnet-5",
        "LLM_SCAN_ALLOWED_KEY_IDS": "",
        "LLM_SCAN_DAILY_CAP": "3000",
        // Mirror the root soft-fail Azure allowance so named production deploys
        // cannot silently fall back to the lower in-code default.
        "SOFT_FAIL_DAILY_CAP": "150",
        // pre-launch dev unlock — mirrored from root vars so the two postures don't
        // diverge; set false at public launch (see router readLlmGate).
        "LLM_SCAN_ALLOW_SOFT_FAIL": "true"
      },
      "kv_namespaces": [
        {
          "binding": "ATTEST_KV",
          "id": "1bfd321b53ab48f2ad45e9b4f18efe03"
        }
      ],
      "r2_buckets": [
        {
          "binding": "SIDELOAD_R2",
          "bucket_name": "resplit-sideload-prod"
        }
      ],
      // Mirrored from root vars so the two postures don't diverge (see root note).
      "analytics_engine_datasets": [
        {
          "binding": "OCR_SCAN_ANALYTICS",
          "dataset": "ocr_scan_recovery"
        }
      ]
    }
  }
}
